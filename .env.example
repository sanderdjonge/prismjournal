# ==============================================
# PrismJournal Environment Variables
# ==============================================
# Copy this file to .env and fill in your values
# Then run: docker compose up -d
# ==============================================

# ==============================================
# REQUIRED - Authentication
# ==============================================

# NextAuth.js secret - generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-here

# Public URL of your application
NEXTAUTH_URL=https://your-domain.com

# ==============================================
# REQUIRED - Database (defaults provided for dev)
# ==============================================

# PostgreSQL connection string
DATABASE_URL=postgresql://prism_dev:prism_dev_password@db:5432/prism_journal_dev

# ==============================================
# OPTIONAL - Notifications
# ==============================================

# Telegram Bot Token for trade notifications
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Telegram webhook secret (set when registering the webhook with Telegram)
TELEGRAM_WEBHOOK_SECRET=

# Resend API key for email notifications
# Get from https://resend.com
RESEND_API_KEY=

# Email sender address (used in From header)
EMAIL_FROM=PrismJournal <noreply@your-domain.com>

# ==============================================
# OPTIONAL - Security
# ==============================================

# Secret for cron job endpoints
CRON_SECRET=your-cron-secret-here

# Trust the host header (required for Cloudflare tunnel)
AUTH_TRUST_HOST=true

# ==============================================
# OPTIONAL - OAuth Providers (uncomment to enable)
# ==============================================

# Google OAuth
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# GitHub OAuth
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Discord OAuth
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=

# ==============================================
# OPTIONAL - Redis (rate limiting)
# ==============================================

# Redis connection URL (enables Redis-backed rate limiting)
REDIS_URL=

# ==============================================
# OPTIONAL - S3 / Cloudflare R2 Backup Storage
# ==============================================

# S3-compatible endpoint (leave empty to disable S3 backups)
# For Cloudflare R2: https://<account_id>.r2.cloudflarestorage.com
# For AWS S3: leave empty (uses default endpoint)
S3_ENDPOINT=

# S3 access credentials
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# S3 bucket name
S3_BUCKET=

# S3 region (use "auto" for Cloudflare R2)
S3_REGION=auto

# ==============================================
# OPTIONAL - Browser Push Notifications
# ==============================================

# VAPID keys for web push notifications
# Generate with: npx tsx scripts/generate-vapid-keys.ts
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Email for VAPID subject (optional, defaults to noreply@prismjournal.com)
VAPID_EMAIL=
