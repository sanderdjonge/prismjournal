# ==============================================
# PrismJournal Environment Variables
# ==============================================
# Copy this file to .env and fill in your values
# Then run: docker compose up -d
# ==============================================

# ==============================================
# REQUIRED - Authentication
# ==============================================

# NextAuth.js secret - generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-here

# Public URL of your application
NEXTAUTH_URL=https://your-domain.com

# ==============================================
# REQUIRED - Database (defaults provided for dev)
# ==============================================

# PostgreSQL connection string
DATABASE_URL=postgresql://prism_dev:prism_dev_password@db:5432/prism_journal_dev

# ==============================================
# OPTIONAL - AI Features (Nebul API)
# ==============================================

# Nebul API key for AI-powered features
NEBUL_API_KEY=

# Nebul API base URL
NEBUL_BASE_URL=https://api.inference.nebul.io/v1

# Nebul model to use
NEBUL_MODEL=Qwen/Qwen3.5-397B-A17B

# ==============================================
# OPTIONAL - Notifications
# ==============================================

# Telegram Bot Token for trade notifications
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Resend API key for email notifications
# Get from https://resend.com
RESEND_API_KEY=

# Email sender address (used in From header)
EMAIL_FROM=PrismJournal <noreply@your-domain.com>

# ==============================================
# OPTIONAL - Security
# ==============================================

# Secret for cron job endpoints
CRON_SECRET=your-cron-secret-here

# Trust the host header (required for Cloudflare tunnel)
AUTH_TRUST_HOST=true

# ==============================================
# OPTIONAL - OAuth Providers (uncomment to enable)
# ==============================================

# Google OAuth
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# GitHub OAuth
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Discord OAuth
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=
