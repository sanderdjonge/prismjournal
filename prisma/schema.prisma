generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// User & Authentication
// ============================================

model User {
  id       String  @id @default(cuid())
  email    String? @unique
  name     String?
  username String? @unique
  password String?

  // 2FA Settings (from TradeLens)
  totpSecret  String? // Base32 secret for Authenticator apps
  totpEnabled Boolean @default(false)

  // Profile
  avatarUrl   String?
  isActive    Boolean   @default(true)
  isSuperuser Boolean   @default(false)
  lastLoginAt DateTime?

  // Settings
  defaultCurrency String @default("EUR")

  // Bridge Key (moved from TradingAccount - one key per user for multi-account support)
  bridgeKeyId   String? @unique // First 12 chars of the key (plain text, used for lookup)
  bridgeKeyHash String? // bcrypt hash of the full key

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  accounts            TradingAccount[]
  strategies          Strategy[]
  notifications       Notification[]
  alertConfig         AlertConfig?
  settings            UserSettings?
  customStats         CustomStat[]
  tags                Tag[]
  passwordResetTokens PasswordResetToken[]
  preTradeNotes       PreTradeNote[]
  challenges          TradingChallenge[]
  checklists          Checklist[]
  createdInviteTokens InviteToken[]  @relation("CreatedInvites")
  usedInviteToken     InviteToken?   @relation("UsedInvite")

  // Social Sharing Settings
  showPrismScoreOnShare Boolean @default(false)

  // Public Profile (for embeddable widget)
  publicProfileId      String? @unique
  publicProfileEnabled Boolean @default(false)
  publicProfileStats   Json? // { showWinRate: bool, showEquityCurve: bool, showPrismScore: bool, showGrowth: bool }

  // Relations
  shareCards ShareCard[]
}

// ============================================
// Trading Accounts (Enhanced with Prop Firm)
// ============================================

model TradingAccount {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  // Basic Info
  name          String
  broker        String?
  accountNumber String? @unique

  // Platform identification (for multi-account routing)
  platform          TradePlatform @default(METATRADER5)
  platformAccountId String? // MT5 login ID, cTrader account ID, etc.

  // Account Type (from TradeLens)
  accountType AccountType @default(OWN_MONEY)

  // Currency & Leverage
  currency String @default("EUR")
  leverage Float  @default(100)

  // Balance Tracking
  balance        Float? // Starting balance
  currentBalance Float? // Live balance from MT5
  currentEquity  Float? // Live equity from MT5

  // MT5 Sync Metrics
  marginUsed   Float?
  freeMargin   Float?
  marginLevel  Float?
  lastSyncTime DateTime?

  // Prop Firm Rules (from TradeLens)
  maxDailyLoss     Float? // Max daily loss allowed
  maxTotalDrawdown Float? // Max total drawdown from starting balance
  profitTarget     Float? // Profit target to pass challenge
  maxPositionSize  Float? // Max lots/contracts per position
  scalingPlan      String? // Notes about scaling rules
  lastDailyReset   DateTime? // Last time daily loss was reset

  // Daily Loss Alert Configuration
  dailyLossAlertThreshold Float? // Alert when daily loss reaches this % of limit (e.g., 80 = alert at 80%)
  dailyLossAlertSentAt    DateTime? // When the last daily loss alert was sent (to avoid spam)

  // Status
  isActive  Boolean @default(true)
  isDefault Boolean @default(false)
  notes     String?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Prop Firm Reference
  propFirmId String?
  propFirm   PropFirm? @relation(fields: [propFirmId], references: [id])

  // Challenge Tracking
  currentPhaseId String?

  // Enhanced Prop Firm Fields
  accountSize Float? // Challenge account size (e.g., 100000)
  profitSplit Float? // Percentage trader gets (e.g., 80.0 = 80%)

  // Restrictions (override from prop firm defaults)
  allowNewsTrading    Boolean?
  allowWeekendHolding Boolean?
  allowEA             Boolean?

  // Auto Chart Screenshots
  autoScreenshotConfig Json? // { enabled: bool, openTimeframes: string[], closeTimeframes: string[], barsOfContext: int }

  // Relations
  trades          Trade[]
  equitySnapshots EquitySnapshot[]
  challengePhases ChallengePhase[]
  violations      RuleViolation[]
  dailySnapshots  DailyAccountSnapshot[]
  preTradeNotes   PreTradeNote[]
  challenges      TradingChallenge[]

  @@unique([userId, platform, platformAccountId])
  @@index([userId])
}

enum AccountType {
  PROPFIRM
  OWN_MONEY
}

// ============================================
// Prop Firm Profiles (Predefined configurations)
// ============================================

model PropFirm {
  id   String @id @default(cuid())
  name String @unique // e.g., "FTMO", "The Funded Trader"
  slug String @unique // URL-friendly identifier

  // Description
  description String?
  website     String?
  logoUrl     String?

  // Challenge Configuration
  challengeType ChallengeType @default(TWO_PHASE)

  // Default Rules
  dailyLossLimit Float        @default(5.0) // Percentage (e.g., 5.0 = 5%)
  maxDrawdown    Float        @default(10.0) // Percentage
  drawdownType   DrawdownType @default(STATIC)

  // Restrictions
  allowNewsTrading    Boolean @default(true)
  allowWeekendHolding Boolean @default(true)
  allowEA             Boolean @default(true)

  // Phases Configuration (stored as JSON)
  phasesConfig Json // JSON with phase configurations

  // Scaling Plan
  hasScalingPlan Boolean @default(false)
  scalingConfig  Json? // JSON with scaling rules

  // Status
  isActive   Boolean @default(true)
  popularity Int     @default(0) // For sorting

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  accounts TradingAccount[]

  @@index([name])
  @@index([slug])
}

enum ChallengeType {
  ONE_PHASE
  TWO_PHASE
  THREE_PHASE
}

enum DrawdownType {
  STATIC // Fixed from starting balance
  TRAILING // Follows account high
}

// ============================================
// Prop Firm Challenge Phase
// ============================================

model ChallengePhase {
  id        String         @id @default(cuid())
  accountId String
  account   TradingAccount @relation(fields: [accountId], references: [id])

  // Phase Info
  phaseNumber Int // 1, 2, or 3
  phaseName   String // "Phase 1", "Verification", "Funded"

  // Targets
  profitTarget       Float? // Percentage target (e.g., 10.0 = 10%)
  profitTargetAmount Float? // Actual dollar amount

  // Limits
  dailyLossLimit Float // Percentage
  maxDrawdown    Float // Percentage

  // Requirements
  minTradingDays Int?
  timeLimitDays  Int?

  // Progress
  status        PhaseStatus @default(IN_PROGRESS)
  startedAt     DateTime    @default(now())
  completedAt   DateTime?
  failedAt      DateTime?
  failureReason String?

  // Metrics (updated daily)
  currentProgress  Float? // Percentage toward profit target
  currentDrawdown  Float? // Current drawdown percentage
  dailyPnl         Float? // Today's P&L
  tradingDaysCount Int    @default(0)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  violations RuleViolation[]

  @@index([accountId])
  @@index([status])
}

enum PhaseStatus {
  IN_PROGRESS
  PASSED
  FAILED
  SKIPPED
}

// ============================================
// Rule Violations
// ============================================

model RuleViolation {
  id        String          @id @default(cuid())
  accountId String
  account   TradingAccount  @relation(fields: [accountId], references: [id])
  phaseId   String?
  phase     ChallengePhase? @relation(fields: [phaseId], references: [id])

  // Violation Details
  ruleType RuleType
  severity ViolationSeverity

  // Values
  limitValue  Float // The rule limit
  actualValue Float // What actually happened

  // Context
  description String
  tradeId     String? // Related trade if applicable

  // Resolution
  isResolved      Boolean   @default(false)
  resolvedAt      DateTime?
  resolutionNotes String?

  // Timestamps
  occurredAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([accountId])
  @@index([ruleType])
  @@index([occurredAt])
}

enum RuleType {
  DAILY_LOSS_LIMIT
  MAX_DRAWDOWN
  NEWS_TRADING
  WEEKEND_HOLDING
  POSITION_SIZE
  TIME_LIMIT
  MIN_TRADING_DAYS
}

enum ViolationSeverity {
  WARNING // Approaching limit
  CRITICAL // At limit
  BREACH // Exceeded limit (account failed)
}

// ============================================
// Daily Account Snapshot
// ============================================

model DailyAccountSnapshot {
  id        String         @id @default(cuid())
  accountId String
  account   TradingAccount @relation(fields: [accountId], references: [id])

  // Date
  snapshotDate DateTime @db.Date

  // Balance Tracking
  startingBalance Float
  endingBalance   Float
  endingEquity    Float

  // P&L
  dailyPnl        Float
  dailyPnlPercent Float

  // Drawdown
  currentDrawdown Float
  maxDrawdown     Float
  highWaterMark   Float

  // Limits Check
  dailyLossUsed         Float // Percentage of daily loss used
  isDailyLimitBreached  Boolean @default(false)
  isMaxDrawdownBreached Boolean @default(false)

  // Progress
  profitProgress Float? // Percentage toward target

  // Timestamps
  createdAt DateTime @default(now())

  @@unique([accountId, snapshotDate])
  @@index([accountId, snapshotDate])
}

// ============================================
// Strategies
// ============================================

model Strategy {
  id          String  @id @default(cuid())
  userId      String
  user        User    @relation(fields: [userId], references: [id])
  name        String
  description String?

  // Phase 19: User-defined strategy rules for plan adherence
  rules Json? // StrategyRules configuration (see StrategyRuleType enum)

  // Phase 23: Linked reusable checklist (replaces inline setupChecklist JSON)
  checklistId String?
  checklist   Checklist? @relation(fields: [checklistId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  trades               Trade[]
  violations           StrategyViolation[]
  checklistCompletions ChecklistCompletion[]

  @@index([userId])
}

// ============================================
// Trades (Merged from both projects)
// ============================================

model Trade {
  id         String         @id @default(cuid())
  accountId  String
  account    TradingAccount @relation(fields: [accountId], references: [id])
  strategyId String?
  strategy   Strategy?      @relation(fields: [strategyId], references: [id])

  // Core trade data
  ticket    String?        @unique // External platform ticket/ID (MT5 ticket, cTrader position ID, etc.)
  symbol    String
  direction TradeDirection
  status    TradeStatus    @default(OPEN)

  // Prices
  entryPrice Float
  exitPrice  Float?
  takeProfit Float?
  stopLoss   Float?

  // Size
  volume  Float  @default(1.0)
  lotSize Float?

  // Timing
  entryTime DateTime
  exitTime  DateTime?

  // Results
  pnl           Float?
  pnlPercent    Float?
  normalizedPnl Float?
  originalPnl   Float?
  commission    Float?
  swap          Float?
  fees          Float? @default(0)

  // Advanced Analytics (from both projects)
  rMultiple Float?
  mae       Float? // Maximum Adverse Excursion
  mfe       Float? // Maximum Favorable Excursion

  // SL Management & Breakeven Tracking
  initialStopLoss Float? // SL at trade open — never overwritten; used for true R calculation
  beTriggered     Boolean @default(false) // true if SL was moved to breakeven or beyond

  // Close reason (SL / TP / MANUAL / EA / STOP_OUT)
  closeReason String?

  // Psychology & Discipline (from TradeLens)
  planCompliance   PlanCompliance?
  mood             Mood?
  entryRating      Int? // 1-5
  exitRating       Int? // 1-5
  managementRating Int? // 1-5
  followedPlan     Boolean?

  // Classification (from TradeLens)
  source          TradeSource @default(MANUAL)
  platform        TradePlatform @default(MANUAL)
  setupType       String?
  
  // Phase 24: Hypothetical/Missed Trade Tracking
  hypotheticalData Json? // Would-be entry/exit data for missed trades

  // Notes
  notes          String?
  entryReason    String?
  exitReason     String?
  lessonsLearned String?

  // External reference
  externalId String? // MT5 ticket or TV order ID

  // Media
  media              Media[]
  pendingScreenshots PendingScreenshot[]
  tags               TradeTag[]
  shareCards         ShareCard[]

  // Phase 20: Pre-trade note linking (reverse relation - FK is on PreTradeNote)
  preTradeNote PreTradeNote?

  // Phase 20: Checklist completion tracking
  checklistCompletion ChecklistCompletion?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([accountId])
  @@index([accountId, entryTime])
  @@index([accountId, exitTime, pnl])
  @@index([accountId, status, exitTime])
  @@index([symbol])
  @@index([status])
}

enum TradeDirection {
  LONG
  SHORT
}

enum TradeStatus {
  OPEN
  CLOSED
  CANCELLED
}

enum TradeSource {
  PAPER
  LIVE
  MANUAL
  MT5_SYNC     // Synced from MT5 platform
  HYPOTHETICAL // Missed trade - trade not taken but tracked
}

enum TradePlatform {
  TRADINGVIEW
  METATRADER5
  CTRADER
  MANUAL
}

enum PlanCompliance {
  FOLLOWED
  DEVIATED
  PARTIAL
}

enum Mood {
  CALM
  CONFIDENT
  NEUTRAL
  ANXIOUS
  FOMO
  REVENGE
}

// ============================================
// Media & Screenshots
// ============================================

model Media {
  id        String   @id @default(cuid())
  tradeId   String
  trade     Trade    @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  filename  String // Stored filename (e.g., "abc123.png")
  filepath  String // Relative path from storage root (e.g., "screenshots/abc123.png")
  mimetype  String // MIME type (e.g., "image/png")
  size      Int // File size in bytes
  type      String // "AUTO", "MANUAL", or "SHARE_CARD"
  timeframe String? // e.g. "M15"
  event     String // "OPEN" or "CLOSE"
  createdAt DateTime @default(now())

  shareCard ShareCard?

  @@index([tradeId])
}

model PendingScreenshot {
  id            String   @id @default(cuid())
  tradeId       String
  trade         Trade    @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  accountId     String
  userId        String
  event         String // "OPEN" or "CLOSE"
  timeframe     String // e.g. "H4"
  interval      String // Twelve Data interval, e.g. "4h"
  symbol        String // Normalised symbol
  entryPrice    Float
  stopLoss      Float?
  takeProfit    Float?
  entryTime     String? // ISO string
  exitTime      String? // ISO string
  scheduledFor  DateTime // eventTime + delay * barDuration
  timezone      String   @default("Europe/Amsterdam")
  barsOfContext Int      @default(25)
  createdAt     DateTime @default(now())

  @@index([scheduledFor])
  @@index([tradeId])
}

// ============================================
// Share Cards (Social Sharing)
// ============================================

model ShareCard {
  id        String   @id @default(cuid())
  tradeId   String
  trade     Trade    @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Card configuration
  includeScreenshot Boolean @default(true)
  showPrismScore    Boolean @default(false)
  platform          String  // "discord" | "twitter" | "reddit" | "general"

  // Visibility - cards are private by default
  isPublic Boolean @default(false)

  // Generated file
  mediaId String? @unique
  media   Media?   @relation(fields: [mediaId], references: [id], onDelete: SetNull)

  // Metadata
  createdAt DateTime @default(now())
  expiresAt DateTime // 24-hour TTL for cleanup

  @@unique([tradeId, userId]) // One card per trade per user - update instead of create duplicates
  @@index([tradeId])
  @@index([userId])
  @@index([expiresAt])
}

model Tag {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  color     String?  @default("#00f2ff") // hex color for UI badge
  createdAt DateTime @default(now())

  trades TradeTag[]

  @@unique([userId, name])
  @@index([userId])
}

model TradeTag {
  id      String @id @default(cuid())
  tradeId String
  trade   Trade  @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  tagId   String
  tag     Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([tradeId, tagId])
  @@index([tradeId])
  @@index([tagId])
}

// ============================================
// Equity Snapshots
// ============================================

model EquitySnapshot {
  id        String         @id @default(cuid())
  accountId String
  account   TradingAccount @relation(fields: [accountId], references: [id])
  balance   Float
  equity    Float
  timestamp DateTime       @default(now())

  @@index([accountId, timestamp])
}

// ============================================
// Currency & Exchange Rates
// ============================================

model Currency {
  code      String  @id
  symbol    String
  name      String
  isDefault Boolean @default(false)
}

model ExchangeRate {
  id        String   @id @default(cuid())
  fromCode  String
  toCode    String
  rate      Float
  timestamp DateTime @default(now())

  @@index([fromCode, toCode, timestamp])
}

// ============================================
// User Settings
// ============================================

model UserSettings {
  userId               String @id
  user                 User   @relation(fields: [userId], references: [id])
  displayCurrency      String @default("USD")
  timezone             String @default("Europe/Amsterdam")
  dateFormat           String @default("DD-MM-YYYY") // DD-MM-YYYY, MM-DD-YYYY, or YYYY-MM-DD
  brokerTimezoneOffset Int    @default(0) // UTC offset of MT5 broker server, e.g. 3 for UTC+3
  dashboardPeriod      String @default("30") // 7, 30, 90, or 365 days
}

// ============================================
// Notifications & Alerts
// ============================================

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

model AlertConfig {
  userId             String  @id
  user               User    @relation(fields: [userId], references: [id])
  enableSync         Boolean @default(true)
  enableTrades       Boolean @default(true)
  enableRisk         Boolean @default(true)
  telegramId         String?
  mddThreshold       Float?
  // Email notification settings
  email              String?
  enableWeeklyDigest Boolean @default(false)
  enableMddAlerts    Boolean @default(false)
  digestFrequency    String  @default("WEEKLY") // WEEKLY or DAILY
  digestSendHour     Int     @default(9) // UTC hour 0-23
  inAppToast         Boolean @default(true)
}

// ============================================
// Custom Statistics (from TradeLens)
// ============================================

model CustomStat {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  name         String
  description  String?
  filterConfig Json // Filter configuration
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
}

// ============================================
// System Metrics (from TradeLens - for Admin)
// ============================================

model SystemMetric {
  id            String   @id @default(cuid())
  timestamp     DateTime @default(now())
  dbSizeMb      Float    @default(0)
  storageSizeMb Float    @default(0)
  totalUsers    Int      @default(0)
  totalTrades   Int      @default(0)
  totalAccounts Int      @default(0)

  @@index([timestamp])
}

// ============================================
// Audit Logs (for Admin Security)
// ============================================

model AuditLog {
  id        String   @id @default(cuid())
  action    String // Enum value from AuditAction
  details   Json // JSON with action details
  ipAddress String?
  userAgent String?
  userId    String? // User who performed the action (null if not authenticated)
  createdAt DateTime @default(now())

  @@index([action])
  @@index([userId])
  @@index([createdAt])
}

// ============================================
// Password Reset Tokens
// ============================================

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenId   String    @unique // First 8 chars of raw token for efficient lookup
  token     String    @unique // Hashed token for security
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([token])
  @@index([tokenId])
  @@index([expiresAt])
}

// ============================================
// Invite Tokens (for invite-only registration)
// ============================================

model InviteToken {
  id        String    @id @default(cuid())
  token     String    @unique // Random token string
  email     String?   // Optional: pre-assigned email
  createdBy String
  creator   User      @relation("CreatedInvites", fields: [createdBy], references: [id], onDelete: Cascade)
  usedBy    String?   @unique
  user      User?     @relation("UsedInvite", fields: [usedBy], references: [id], onDelete: SetNull)
  usedAt    DateTime?
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  @@index([token])
  @@index([createdBy])
  @@index([usedBy])
  @@index([createdAt])
}

// ============================================
// System Settings
// ============================================

model SystemSettings {
  id              String  @id @default("system")
  inviteOnlyMode  Boolean @default(false)
  updatedAt       DateTime @updatedAt
}

// ============================================
// Strategy Rules (Phase 19 - Plan Adherence)
// ============================================

enum StrategyRuleType {
  MAX_DAILY_LOSS // Max loss allowed per day (currency or %)
  MAX_DAILY_TRADES // Max number of trades per day
  MIN_RR_RATIO // Minimum risk/reward ratio required
  ALLOWED_TIME_WINDOWS // Only trade during specific hours
  ALLOWED_SYMBOLS // Only trade specific instruments
  MAX_POSITION_SIZE // Max lots/contracts per position
  NO_OVERTRADING // Prevent excessive trades in short time
  MANDATORY_STOP_LOSS // Require stop loss on every trade
  MAX_HOLDING_TIME // Max time to hold a position
  MIN_HOLDING_TIME // Min time before closing (prevent scalping impulse)
}

model StrategyViolation {
  id         String   @id @default(cuid())
  strategyId String
  strategy   Strategy @relation(fields: [strategyId], references: [id], onDelete: Cascade)
  tradeId    String
  userId     String
  accountId  String

  // Violation Details
  ruleId      String // Matches the rule id from Strategy.rules JSON
  ruleType    StrategyRuleType
  limitValue  Float // The rule limit
  actualValue Float // What actually happened

  // Impact Analysis
  pnlImpact Float? // P&L of the violating trade

  // Timestamps
  occurredAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([strategyId])
  @@index([userId])
  @@index([accountId])
  @@index([ruleType])
  @@index([occurredAt])
}

model TiltmeterSnapshot {
  id        String  @id @default(cuid())
  userId    String
  accountId String? // Optional - can be user-wide or per-account

  // Score (0 = zen/master discipline, 100 = full tilt)
  score Float

  // Breakdown by rule type for detailed analysis
  components Json // { [ruleType]: { count, weightedScore } }

  // Period
  periodStart DateTime
  periodEnd   DateTime

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([accountId])
  @@index([periodStart, periodEnd])
}

// ============================================
// Checklists (Phase 23 — standalone reusable)
// ============================================

model Checklist {
  id         String          @id @default(cuid())
  userId     String
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  items      ChecklistItem[]
  strategies Strategy[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model ChecklistItem {
  id          String    @id @default(cuid())
  checklistId String
  checklist   Checklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  label       String
  required    Boolean   @default(false)
  order       Int       @default(0)

  @@index([checklistId])
}

// ============================================
// Pre-Trade Notes (Phase 20)
// ============================================

enum PreTradeNoteStatus {
  PENDING // Created, waiting for trade
  LINKED // Linked to a trade
  NOT_RELEVANT // User marked as not relevant
  EXPIRED // Not linked within reasonable time (optional)
}

model PreTradeNote {
  id        String          @id @default(cuid())
  userId    String
  user      User            @relation(fields: [userId], references: [id])
  accountId String? // Optional: specific account intended
  account   TradingAccount? @relation(fields: [accountId], references: [id])

  // Planned trade details
  symbol       String
  direction    TradeDirection
  body         String         @db.Text // Analysis/rationale
  plannedEntry Float? // Optional planned entry price

  // Linking to actual trade
  status   PreTradeNoteStatus @default(PENDING)
  trade    Trade?             @relation(fields: [tradeId], references: [id])
  tradeId  String?            @unique
  linkedAt DateTime?

  // Setup checklist completion (if strategy assigned later)
  checklistStatus Json? // { [checklistId]: boolean }

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([userId, status])
  @@index([tradeId])
  @@index([symbol, direction])
}

// ============================================
// Economic Events (Phase 21b)
// ============================================

enum EconomicEventImpact {
  LOW
  MEDIUM
  HIGH
}

model EconomicEvent {
  id String @id @default(cuid())

  // Event details
  name     String // "FOMC", "NFP", "CPI", etc.
  date     DateTime            @db.Date
  time     String? // "14:30 EST"
  currency String // "USD", "EUR", "GBP", etc.
  impact   EconomicEventImpact @default(MEDIUM)

  // Values
  forecast String?
  actual   String?
  previous String?

  // Source tracking
  source     String? // "ForexFactory", "FMP", etc.
  externalId String? @unique // ID from external API

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@index([currency])
  @@index([impact])
}

// ============================================
// Trading Challenges (Phase 22)
// ============================================

enum ChallengeScope {
  GLOBAL // All accounts combined
  PER_ACCOUNT // Specific account only
}

model TradingChallenge {
  id        String          @id @default(cuid())
  userId    String
  user      User            @relation(fields: [userId], references: [id])
  accountId String? // Set if scope is PER_ACCOUNT
  account   TradingAccount? @relation(fields: [accountId], references: [id])

  // Challenge details
  name        String
  description String?
  scope       ChallengeScope @default(GLOBAL)

  // Rules (reuse StrategyRuleType pattern)
  rules Json // [{ type, value, operator }] - same structure as Strategy.rules

  // Duration
  startDate DateTime
  endDate   DateTime?
  isActive  Boolean   @default(true)

  // Progress (denormalized for performance)
  daysPassed Int @default(0)
  daysFailed Int @default(0)
  totalDays  Int @default(0)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  evaluations ChallengeEvaluation[]

  @@index([userId, isActive])
  @@index([accountId])
  @@index([startDate])
}

model ChallengeEvaluation {
  id          String           @id @default(cuid())
  challengeId String
  challenge   TradingChallenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  // Evaluation
  date           DateTime @db.Date
  passed         Boolean
  failureReasons Json? // Array of rule IDs that failed

  // Linked trades for this day
  tradeIds String[] // Array of trade IDs evaluated

  createdAt DateTime @default(now())

  @@unique([challengeId, date])
  @@index([challengeId, date])
  @@index([passed])
}

// ============================================
// Checklist Completion (Phase 20 - Trade-level)
// ============================================

model ChecklistCompletion {
  id         String   @id @default(cuid())
  tradeId    String
  trade      Trade    @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  strategyId String
  strategy   Strategy @relation(fields: [strategyId], references: [id])

  // Checklist state at time of trade
  checklist Json // [{ id, label, checked }]

  // Summary
  totalItems    Int
  checkedItems  Int
  completionPct Float // 0-100

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tradeId])
  @@index([strategyId])
  @@index([completionPct])
}
